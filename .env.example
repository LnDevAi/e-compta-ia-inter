POSTGRES_DB=ecompta
POSTGRES_USER=ecompta
POSTGRES_PASSWORD=changeme_strong_password

REDIS_PASSWORD=changeme_redis_password

JWT_SECRET=changeme_at_least_64_chars_random_secret_key_for_production_use
JWT_EXPIRATION_MS=86400000

ANTHROPIC_API_KEY=sk-ant-api03-changeme

# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://app.mondomaine.com

# HikariCP pool size (default 20 in prod profile)
DB_POOL_SIZE=20

# Notifications email (MAIL_ENABLED=true pour activer)
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre-compte@gmail.com
MAIL_PASSWORD=votre-mot-de-passe-application
MAIL_FROM=noreply@votre-domaine.com

# ── Licence locale (on-premise) ───────────────────────────────────────────────
# false = vérifie le fichier licence.lic  |  true = mode dev (tous modules actifs)
LICENCE_DEV_MODE=false
# Clé publique RSA-2048 au format Base64 DER — générée par tools/generate-keys.sh
LICENCE_PUBLIC_KEY=REMPLACER_PAR_CLES_GENEREES_VIA_tools/generate-keys.sh

# ── SMS (optionnel) ───────────────────────────────────────────────────────────
SMS_PROVIDER=mock
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=eCompta
